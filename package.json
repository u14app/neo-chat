{
  "name": "neo-chat",
  "description": "An omni AI chat application with a clean UI and excellent performance.",
  "private": true,
  "version": "2.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview:worker": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:worker": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "byok:generate": "node scripts/generate-byok-key.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "localforage": "^1.10.0",
    "lucide-react": "1.23.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "openai": "^6.15.0",
    "opfs-tools": "^0.7.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^13.0.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
